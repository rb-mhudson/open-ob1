# Supabase project credentials
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared secret for MCP client authentication (x-brain-key header or ?key= param)
# Generate a strong random string — treat like a password
MCP_ACCESS_KEY=your-secret-access-key-here

# OpenRouter API key for embeddings + metadata extraction
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

